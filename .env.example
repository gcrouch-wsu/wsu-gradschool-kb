KB_ADMIN_EMAIL=admin@example.edu
KB_ADMIN_PASSWORD=ChangeMe123!
KB_ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Alias names also supported:
# BOOTSTRAP_OWNER_EMAIL=admin@example.edu
# BOOTSTRAP_OWNER_PASSWORD=ChangeMe123!
# BOOTSTRAP_OWNER_SESSION_SECRET=replace-with-a-long-random-secret

# Optional: Neon Postgres connection string for durable KB content.
# When unset, the app serves the in-memory seed dataset (fine for local dev,
# not durable). When set, the schema is auto-created and seeded on first run.
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Optional: Vercel Blob token for importing images from .docx uploads.
# Set automatically on Vercel when a Blob store is connected; pull locally with
# `vercel env pull`. When unset, DOCX import skips images (text still imports).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Required for the scheduled audit-log retention route in production.
# CRON_SECRET="b506be1537e2b763b479135e6ca47040a0b53f11860b777b6640283d7fa8273b"

# Optional: HTTP email provider for weekly review-date digest emails.
# When EMAIL_PROVIDER_URL is unset, the digest logs structured JSON and does
# not fail the cron run.
# EMAIL_PROVIDER_URL=https://email-provider.example/send
# EMAIL_PROVIDER_TOKEN=provider-token
# EMAIL_FROM="WSU Graduate School KB <no-reply@example.edu>"
